function run-perl {
  _ensure-host-env
  DIR=$PWD docker compose -f tools/perl/docker-compose.yml run perl "$@"
}

function perl-shell {
  _ensure-host-env
  DIR=$PWD docker compose \
  -f tools/perl/docker-compose.yml \
  run \
  -it \
  --entrypoint bash \
  perl
}

#
# Runs a shell command using the perl image
#
# TODO: replace with a simple, tiny alpine linux.
#
function perl-shell-command {
  _ensure-host-env

  echo ""
  echo "> perl-shell-command: $@ "
  echo ""

  DIR=$PWD docker compose \
  -f tools/perl/docker-compose.yml \
  run \
  --rm \
  --entrypoint "" \
  perl "$@"
}

function run-perl-hello {
  _ensure-host-env
  DIR=$PWD docker compose \
  -f tools/perl/docker-compose.yml \
  run \
  --rm \
  -e NAME="${NAME}" \
  perl "${TOOLS_DIR}/perl/hello.pl" "$@"
}

function perl-shell {
  _ensure-host-env
  DIR=$PWD docker compose \
  -f tools/perl/docker-compose.yml \
  run \
  --rm \
  -e NAME="${NAME}" \
  --entrypoint "bash" \
  perl
}

function perl-render {
  _ensure-host-env
  DIR=$PWD docker compose \
  -f tools/perl/docker-compose.yml \
  run \
  --rm \
  perl "${TOOLS_DIR}/perl/render.pl" "$@"
}

