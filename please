#!/bin/bash

#
# CONFIG
#
PROJECT_DIR="${PWD}"
APP_DIR=/app
BUILD_DIR=/app/build
SOURCE_DIR=/app/source
PROD_DIR=/app
SITES_DIR=/app/source/sites
TOOLS_DIR=/app/tools
HTTPD_USER=www-data
HTTPD_GROUP=www-data
APP_ROOT=/app/build

#
# PRIVATE
#

function _noop {
    echo "Not implemented yet"
}


################################################################################
#
# Internal functions
#
################################################################################

function _ensure-docker-env {
  if ! [ -f /.dockerenv ]; then
    echo "Sorry, this task only runs in a docker container; abandoning task"
    exit 1
  fi
}

function _ensure-host-env {
  if [ -f /.dockerenv ]; then
    echo "Sorry, this task only runs in the host environment; abandoning task"
    exit 1
  fi
}

################################################################################
#
# Development tools
#
#################################################################################

function build-dev-image {
  _ensure-host-env
  docker build --file tools/dev/Dockerfile -t jazz-democracy:dev .
}

function shell-dev-image {
  _ensure-host-env
  DIR="$PWD" docker compose -f tools/dev/docker-compose.yml run --rm --service-ports --entrypoint bash adapt-site
}

function shell-into-dev-image {
  _ensure-host-env
  APP_ROOT=${APP_ROOT} DIR="$PWD" docker compose -f tools/dev/docker-compose.yml exec dev bash
}

function generate-dev-cert {
    mkcert -cert-file ./tools/proxy/contents/ssl/test.crt --key-file ./tools/proxy/contents/ssl/test.key tech.web4humans.com

    env bash tools/make-dev-cert.sh
}
